msgid "No signatures found in this PDF."
msgstr "V tomto PDF nebyly nalezeny žádné podpisy."

msgid "Could not extract signer certificate"
msgstr "Certifikát podepisující osoby se nepodařilo načíst"

msgid "QUALIFIED e-signature — natural person (eIDAS Art. 3(12))"
msgstr "KVALIFIKOVANÝ elektronický podpis — fyzická osoba (eIDAS čl. 3 odst. 12)"

msgid "QUALIFIED e-seal — legal person (eIDAS Art. 3(27))"
msgstr "KVALIFIKOVANÝ elektronický podpis — právnická osoba (\"seal\"/pečeť, eIDAS čl. 3 odst. 27)"

msgid "Trusted, but cert lacks a qualified-signature QCStatement"
msgstr "Důvěryhodný, ale certifikát nemá QCStatement kvalifikovaného podpisu"

msgid "Cryptographically valid, but not chaining to an EU TL anchor"
msgstr "Kryptograficky platný, ale neřetězí se ke kořenovému CA certifikátu EU TL"

msgid "Failed cryptographic validation (modified/invalid/revoked)"
msgstr "Neúspěšné kryptografické ověření (změněno/neplatné/odvolané)"

msgid "Cert carries qualified natural-person QCStatements (validation skipped)"
msgstr "Certifikát nese QCStatements kvalifikované fyzické osoby (ověření přeskočeno)"

msgid "Validation skipped"
msgstr "Ověření přeskočeno"

msgid "File"
msgstr "Soubor"

msgid "Help"
msgstr "Nápověda"

msgid "Open Recent"
msgstr "Otevřít nedávné"

msgid "Open…"
msgstr "Otevřít…"

msgid "Quit"
msgstr "Ukončit"

msgid "About"
msgstr "O aplikaci"

msgid "PDF qualified signature validation from EU TL CA roots PyQt utility."
msgstr "Nástroj PyQt pro ověřování kvalifikovaných podpisů PDF vůči kořenům CA z EU TL."
